{
  "defaultMode": "deny",
  "permissions": {
    "tools": {
      "read": {
        "default": "allow",
        "paths": { "deny": [".env*", "~/.ssh/*"] }
      },
      "write": {
        "default": "deny",
        "paths": {
          "allow": ["kb/active/*", "tmp/*"],
          "deny": ["kb/reference/*", "kb/history/*", "tools/*", "bin/*", ".env*"]
        }
      },
      "edit": {
        "default": "deny",
        "paths": { "allow": ["kb/observations.md"], "deny": [".env*"] }
      },
      "bash": {
        "default": "deny",
        "deny": [
          "*.env*", "*/.ssh/*", "rm *", "sudo *",
          "curl *", "wget *", "python *", "python3 *", "pip *", "npm *"
        ],
        "allow": [
          "bin/*",
          "git status*", "git log*", "git add *", "git commit*",
          "git mv kb/active/* kb/history/*"
        ]
      },
      "grep": "deny",
      "find": "deny",
      "ls": "deny"
    }
  }
}
